{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>LinkedIn share queue | {{ site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>Posts flagged to be shared on LinkedIn</description>
    <atom:link href="{{ .Permalink }}linkedin.xml" rel="self" type="application/rss+xml" />
    {{- range where .RegularPages "Params.sharelinkedin" true }}
    {{- /* LinkedIn hashtags are alphanumeric only, so "Azure Functions" becomes #AzureFunctions */}}
    {{- $hashtags := slice }}
    {{- range .Params.tags }}
      {{- $hashtags = $hashtags | append (printf "#%s" (replaceRE `[^A-Za-z0-9]` "" .)) }}
    {{- end }}
    <item>
      <title>{{ .Title | plainify }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Description | default .Summary | plainify }}{{ with $hashtags }}&#10;&#10;{{ delimit . " " }}{{ end }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
